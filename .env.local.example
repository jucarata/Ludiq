# Copia este archivo como .env.local y rellena los valores.

# Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_tu_clave_aqui
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_aqui

# Privy Dashboard → https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=tu_privy_app_id
PRIVY_APP_SECRET=tu_privy_app_secret

# Competitive mode — set to "mainnet" for Proof of Ship / production
# or "sepolia" for testnet.
NEXT_PUBLIC_CELO_CHAIN=mainnet

# Mainnet RPC (when NEXT_PUBLIC_CELO_CHAIN=mainnet)
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org
CELO_RPC_URL=https://forno.celo.org

# Sepolia RPC (only when NEXT_PUBLIC_CELO_CHAIN=sepolia)
# NEXT_PUBLIC_CELO_CHAIN=sepolia
# NEXT_PUBLIC_CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org
# CELO_SEPOLIA_RPC_URL=https://forno.celo-sepolia.celo-testnet.org

# Escrow (deploy CompetitiveEscrow, then paste address)
NEXT_PUBLIC_ESCROW_ADDRESS=
NEXT_PUBLIC_COMMISSION_WALLET=
# Must match the escrow contract owner (used for lock + settle)
ESCROW_OWNER_PRIVATE_KEY=
